$begin 'CacheDataVersion'
	DataVersion=-1
$end 'CacheDataVersion'
$begin 'VariableValues'
	h='4mm'
	gnl='80mm'
	gnw='80mm'
	pl='25mm'
	pw='25mm'
	a='Patch_pos_x+pw/2'
	r1='1.8mm'
	r2='1.67mm'
	r3='0.5mm'
	dummy='a +offset'
	offset='6.1mm'
	Patch_pos_x='gnw/2 - pw/2'
	Patch_pos_y='gnl/2 - pl/2'
$end 'VariableValues'
